# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ── Database (used by FastAPI via SQLAlchemy) ─────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_<your-resend-key>

# ── Deployment ────────────────────────────────────────────────────────────────
RAILWAY_FASTAPI_URL=https://<your-service>.up.railway.app

# ── Frontend (Vite — prefix with VITE_ to expose to the browser) ─────────────
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>
VITE_RAILWAY_FASTAPI_URL=https://<your-service>.up.railway.app
